--source include/have_debug.inc

--disable_warnings
--let $rpl_topology= 1->2->3
--source include/rpl_init.inc
--enable_warnings

--echo ###########################################################################
--echo # 0. Prepare, InnoDB (server_1) -> DuckDB (server_2) -> DuckDB (server_3)
--echo ###########################################################################
--connection server_1
--echo [connection server_1]
CREATE TABLE t1 (
    id BIGINT NOT NULL,
    c0 VARCHAR(20) NOT NULL,
    PRIMARY KEY(id)
) ENGINE=InnoDB;
SHOW CREATE TABLE t1;

--source include/rpl_sync.inc
--connection server_2
--echo [connection server_2]
SHOW CREATE TABLE t1;

--connection server_3
--echo [connection server_3]
SHOW CREATE TABLE t1;

--echo ###########################################################################
--echo # 1. Test server_2 Commit Error
--echo ###########################################################################
--connection server_2
--echo [connection server_2]
--source include/stop_slave_sql.inc

--connection server_1
--echo [connection server_1]
INSERT INTO t1 VALUES (1, 'xxx'), (2, 'yyy');
UPDATE t1 SET c0 = 'zzz' WHERE id = 1;

--let $rpl_only_running_threads=1
--source include/rpl_sync.inc

--connection server_2
--echo [connection server_2]
--disable_query_log
call mtr.add_suppression("MY-010583");
call mtr.add_suppression("MY-010584");
call mtr.add_suppression("MY-013121");
--enable_query_log

SET GLOBAL debug = "+d,simulate_duckdb_commit_failed";
--source include/start_slave_sql.inc
--let $slave_sql_errno = 13121
--source include/wait_for_slave_sql_error.inc

SET GLOBAL debug = "-d,simulate_duckdb_commit_failed";
--source include/start_slave_sql.inc

--source include/rpl_sync.inc
--let $rpl_diff_statement = SELECT id, c0 FROM test.t1 ORDER BY id;
--source include/rpl_diff.inc

--echo ###########################################################################
--echo # Cleanup
--echo ###########################################################################
--connection server_1
--echo [connection server_1]
DROP TABLE t1;
--source include/rpl_sync.inc
--source include/rpl_end.inc
