#
# 3) TEST DUCKDB UDF
#
DROP TABLE t1;
CREATE TABLE t1 (
id BIGINT PRIMARY KEY,
expr       VARCHAR(255) NOT NULL,
pat        VARCHAR(255) NOT NULL,
repl       VARCHAR(255) NOT NULL DEFAULT '#',
pos        INT NOT NULL DEFAULT 1,
occurrence INT NOT NULL DEFAULT 1,
return_opt INT NOT NULL DEFAULT 0,
match_type VARCHAR(16) NOT NULL DEFAULT 'c',
j1 JSON NOT NULL,
j2 JSON NOT NULL,
-- JSON
g_json_overlaps BOOLEAN GENERATED ALWAYS AS (
JSON_OVERLAPS(j1, j2)
) STORED,
g_json_depth INT GENERATED ALWAYS AS (
JSON_DEPTH(j1)
) STORED,
g_json_unquote VARCHAR(255) GENERATED ALWAYS AS (
JSON_UNQUOTE(JSON_EXTRACT(j1, '$.s'))
) STORED,
-- REGEXP
g_rlike BOOLEAN GENERATED ALWAYS AS (
REGEXP_LIKE(expr, pat, match_type)
) STORED,
-- REGEXP_INSTR cause mysql-server crash if more than 4 parameters.
g_rinstr INT GENERATED ALWAYS AS (
-- REGEXP_INSTR(expr, pat, pos, occurrence, return_opt, match_type)
REGEXP_INSTR(expr, pat, pos, occurrence)
) STORED,
g_rsubs VARCHAR(255) GENERATED ALWAYS AS (
REGEXP_SUBSTR(expr, pat, pos, occurrence, match_type)
) STORED,
g_rrepl VARCHAR(255) GENERATED ALWAYS AS (
REGEXP_REPLACE(expr, pat, repl, pos, occurrence, match_type)
) STORED
);
INSERT INTO t1 (id, expr, pat, repl, pos, occurrence, return_opt, match_type, j1, j2) VALUES
(1, 'abc123xyz456', '[0-9]+', '<N>', 1, 1, 0, 'c',
JSON_OBJECT('s','"hello"', 'a', JSON_ARRAY(1,2,3)),
JSON_OBJECT('a', JSON_ARRAY(2), 'k', 1)
),
(2, 'foo11bar22baz33', '[0-9]+', '#', 4, 2, 0, 'c',
JSON_OBJECT('s','world', 'x', JSON_OBJECT('y',1)),
JSON_OBJECT('x', JSON_OBJECT('y',1))
),
(3, 'abcxxaBCyy', 'abc', '*', 1, 1, 0, 'i',
JSON_OBJECT('s','no_quotes', 'k', JSON_ARRAY(JSON_OBJECT('z',1))),
JSON_OBJECT('k', JSON_ARRAY(JSON_OBJECT('z',2)))
);
include/rpl_sync.inc
[connection slave]
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` bigint NOT NULL,
  `expr` varchar(255) NOT NULL,
  `pat` varchar(255) NOT NULL,
  `repl` varchar(255) NOT NULL DEFAULT '#',
  `pos` int NOT NULL DEFAULT '1',
  `occurrence` int NOT NULL DEFAULT '1',
  `return_opt` int NOT NULL DEFAULT '0',
  `match_type` varchar(16) NOT NULL DEFAULT 'c',
  `j1` json NOT NULL,
  `j2` json NOT NULL,
  `g_json_overlaps` tinyint(1) GENERATED ALWAYS AS (json_overlaps(`j1`,`j2`)) STORED,
  `g_json_depth` int GENERATED ALWAYS AS (json_depth(`j1`)) STORED,
  `g_json_unquote` varchar(255) GENERATED ALWAYS AS (json_unquote(json_extract(`j1`,_utf8mb4'$.s'))) STORED,
  `g_rlike` tinyint(1) GENERATED ALWAYS AS (regexp_like(`expr`,`pat`,`match_type`)) STORED,
  `g_rinstr` int GENERATED ALWAYS AS (regexp_instr(`expr`,`pat`,`pos`,`occurrence`)) STORED,
  `g_rsubs` varchar(255) GENERATED ALWAYS AS (regexp_substr(`expr`,`pat`,`pos`,`occurrence`,`match_type`)) STORED,
  `g_rrepl` varchar(255) GENERATED ALWAYS AS (regexp_replace(`expr`,`pat`,`repl`,`pos`,`occurrence`,`match_type`)) STORED,
  PRIMARY KEY (`id`)
) ENGINE=DUCKDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
