[connection master]
INSERT INTO t1(id, a, b, content) VALUES (1, 2, 4, '{"val1":1,"val2":"name_001","val3":1.01}');
INSERT INTO t1(id, a, b, content) VALUES (2, 4, 6, '{"val1":2,"val2":"name_002","val3":2.02}');
INSERT INTO t1(id, a, b, content) VALUES (3, 6, 9, '{"val1":3,"val2":"name_003","val3":3.03}');
INSERT INTO t2(id, created_at) VALUES (1, '2025-01-01 00:00:00');
INSERT INTO t2(id, created_at) VALUES (2, '2025-02-02 00:00:00');
INSERT INTO t2(id, created_at) VALUES (3, '2025-03-03 00:00:00');
