#
# 4. Valid free flush binlog transaction compression.
########################################################
#
[connection master]
SET binlog_transaction_compression_level_zstd = 1;
SET binlog_transaction_compression = ON;
SET debug = "+d,free_flush_skip_limit_size_check";
INSERT INTO rpl_test.t2 SELECT * FROM rpl_test.t1;
# Check binlog and data. Expect 10 binlog files and ignorable event exist in the 9th binlog.
SHOW BINARY LOGS;
Log_name	File_size	Encrypted
master-bin.000001	#	#
master-bin.000002	#	#
master-bin.000003	#	#
master-bin.000004	#	#
master-bin.000005	#	#
master-bin.000006	#	#
master-bin.000007	#	#
master-bin.000008	#	#
master-bin.000009	#	#
master-bin.000010	#	#
SELECT COUNT(*) FROM rpl_test.t2;
COUNT(*)
6
include/show_binlog_events.inc
Log_name	Pos	Event_type	Server_id	End_log_pos	Info
master-bin.000009	#	Ignorable	#	#	# Unrecognized ignorable event
master-bin.000009	#	Transaction_payload	#	#	compression='ZSTD', decompressed_size=## bytes
master-bin.000009	#	Query	#	#	BEGIN
master-bin.000009	#	Table_map	#	#	table_id: # (rpl_test.t2)
master-bin.000009	#	Write_rows	#	#	table_id: #
master-bin.000009	#	Write_rows	#	#	table_id: # flags: STMT_END_F
master-bin.000009	#	Xid	#	#	COMMIT /* XID */
master-bin.000009	#	Rotate	#	#	master-bin.000010;pos=POS
include/rpl_sync.inc
[connection slave]
SHOW BINARY LOGS;
Log_name	File_size	Encrypted
slave-bin.000001	#	#
slave-bin.000002	#	#
slave-bin.000003	#	#
slave-bin.000004	#	#
slave-bin.000005	#	#
slave-bin.000006	#	#
slave-bin.000007	#	#
SELECT COUNT(*) FROM rpl_test.t2;
COUNT(*)
