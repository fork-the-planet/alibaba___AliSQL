[connection master]
#
# 1. Make test data.
########################################################
#
[connection master]
CREATE DATABASE rpl_test;
CREATE TABLE rpl_test.t1 (s LONGTEXT);
CREATE TABLE rpl_test.t2 (s LONGTEXT);
CALL mtr.add_suppression("Binary logging not possible.");
CALL mtr.add_suppression("Attempting backtrace. You can use the following information to find out");
CALL mtr.add_suppression("Binlog cache free flush failed because failed to flush gtid event");
CALL mtr.add_suppression("Binlog cache free flush failed because failed to rename temp file.");
CALL mtr.add_suppression("Binlog cache free flush message: check reserve space for front events is not enough");
FLUSH BINARY LOGS;
#
# 2. Test rename fail will crash the server.
########################################################
#
[connection master]
SET DEBUG = "+d,simulate_binlog_cache_free_flush_rename_fail";
BEGIN;
INSERT INTO rpl_test.t2 SELECT * FROM rpl_test.t1;
COMMIT;
ERROR HY000: Binary logging not possible. Message: An error occurred during sync stage of the commit. 'binlog_error_action' is set to 'ABORT_SERVER'. Server is being stopped.
include/rpl_start_server.inc [server_number=1]
# Check no binlog cache temp file exist.
# Check binlog and data. Expect 3 binlog files.
[connection master]
SHOW BINARY LOGS;
Log_name	File_size	Encrypted
master-bin.000001	#	#
master-bin.000002	#	#
master-bin.000003	#	#
SELECT COUNT(*) FROM rpl_test.t2;
COUNT(*)
0
include/rpl_sync.inc
[connection slave]
SHOW BINARY LOGS;
Log_name	File_size	Encrypted
slave-bin.000001	#	#
SELECT COUNT(*) FROM rpl_test.t2;
COUNT(*)
0
#
# 3. Test reserved space not enough will go back to original logic.
########################################################
#
[connection master]
SET debug = "+d,simulate_small_rds_binlog_cache_reserved_space";
INSERT INTO rpl_test.t2 SELECT * FROM rpl_test.t1;
SET debug = "-d,simulate_small_rds_binlog_cache_reserved_space";
# Check binlog and data. Expect 3 binlog files, and no ignorable event in binlog.
SHOW BINARY LOGS;
Log_name	File_size	Encrypted
master-bin.000001	#	#
master-bin.000002	#	#
master-bin.000003	#	#
SELECT COUNT(*) FROM rpl_test.t2;
COUNT(*)
2
include/assert_binlog_events.inc [Gtid # !Begin # !Insert # Write_rows # !Commit]
include/rpl_sync.inc
[connection slave]
SHOW BINARY LOGS;
Log_name	File_size	Encrypted
slave-bin.000001	#	#
slave-bin.000002	#	#
slave-bin.000003	#	#
SELECT COUNT(*) FROM rpl_test.t2;
COUNT(*)
2
include/assert_binlog_events.inc [Ignorable # Gtid # !Begin # !Insert # Write_rows # !Commit]
#
# 4. Test binlog cache free flush crash safe.
# 4.1. Test crash after create purge index file for old binlog file.
########################################################
#
[connection master]
SET debug = "+d,crash_create_non_critical_before_update_index";
INSERT INTO rpl_test.t2 SELECT * FROM rpl_test.t1;
ERROR HY000: Lost connection to MySQL server during query
include/rpl_start_server.inc [server_number=1]
# Check binlog and data. Expect 4 binlog files.
SHOW BINARY LOGS;
Log_name	File_size	Encrypted
master-bin.000001	#	#
master-bin.000002	#	#
master-bin.000003	#	#
master-bin.000004	#	#
include/rpl_sync.inc
[connection slave]
SHOW BINARY LOGS;
Log_name	File_size	Encrypted
slave-bin.000001	#	#
slave-bin.000002	#	#
slave-bin.000003	#	#
SELECT COUNT(*) FROM rpl_test.t2;
COUNT(*)
2
