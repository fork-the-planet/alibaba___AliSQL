DROP TABLE customers, orders;
CREATE TABLE t1(a INT AUTO_INCREMENT KEY, b int) ENGINE = InnoDB;
INSERT INTO t1(b) VALUES(1), (2);
INSERT INTO t1(b) SELECT b FROM t1;
INSERT INTO t1(b) SELECT b FROM t1;
INSERT INTO t1(b) SELECT b FROM t1;
INSERT INTO t1(b) SELECT b FROM t1;
