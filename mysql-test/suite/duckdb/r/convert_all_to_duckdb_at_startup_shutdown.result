INSERT INTO t1(b) SELECT b FROM t1;
CREATE TABLE t2 LIKE t1;
INSERT INTO t2 SELECT * FROM t1;
CREATE TABLE t3 LIKE t1;
INSERT INTO t3 SELECT * FROM t1;
CREATE TABLE t4 LIKE t1;
INSERT INTO t4 SELECT * FROM t1;
# restart: --duckdb_convert_all_at_startup=ON --duckdb_convert_all_skip_mtr_db=ON --log-error=MYSQLD_ERROR_LOG --debug=+d,duckdb_convert_sleep_during_parallel_alter --duckdb_convert_all_at_startup_threads=2
