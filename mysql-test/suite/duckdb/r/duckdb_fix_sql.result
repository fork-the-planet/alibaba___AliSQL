DROP TABLE t1;
CREATE TABLE t1 (
id INT PRIMARY KEY,
col1 DATE,
col2 TIMESTAMP,
col3 DATETIME,
col4 TIME,
col5 TIMESTAMP(6),
col6 TIME(6)
);
CREATE TABLE t_int (
id INT PRIMARY KEY,
lower BIGINT,
higher BIGINT,
equal BIGINT
);
CREATE TABLE t_decimal (
id INT PRIMARY KEY,
lower DECIMAL(38, 10),
higher DECIMAL(38, 10),
equal DECIMAL(38, 10)
);
CREATE TABLE t_double (
id INT PRIMARY KEY,
lower DOUBLE,
higher DOUBLE,
equal DOUBLE
);
