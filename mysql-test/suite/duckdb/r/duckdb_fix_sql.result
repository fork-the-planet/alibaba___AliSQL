CREATE TABLE t1 (id INT PRIMARY KEY, col1 DECIMAL(18, 2), col2 INT) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1, 9999999999999999.99, 99999999);
SELECT col1 * col1 FROM t1;
ERROR HY000: [DuckDB] Out of Range Error: Overflow in multiplication of DECIMAL(18) (999999999999999999 * 999999999999999999). You might want to add an explicit cast to a bigger decimal..
SELECT col2 * 1.00000000001 FROM t1;
ERROR HY000: [DuckDB] Out of Range Error: Overflow in multiplication of DECIMAL(18) (99999999 * 100000000001). You might want to add an explicit cast to a bigger decimal..
SELECT col1 + col2 FROM t1;
ERROR HY000: [DuckDB] Out of Range Error: Overflow in addition of DECIMAL(18) (999999999999999999 + 9999999900). You might want to add an explicit cast to a bigger decimal..
SET duckdb_prefer_high_precision = true;
SELECT col1 * col1, col2 * 1.00000000001, col1 + col2 FROM t1;
