SET NAMES utf8mb4;
# 3.4 define collation for table with latin1
set names latin1;
CREATE TABLE t_duckdb (id INT PRIMARY KEY, a varchar(32) COLLATE latin1_general_ci) engine=duckdb CHARSET=latin1 COLLATE=latin1_general_ci;
CREATE TABLE t_innodb (id INT PRIMARY KEY, a varchar(32) COLLATE latin1_general_ci) engine=innodb CHARSET=latin1 COLLATE=latin1_general_ci;
