SET NAMES 'utf8mb4' COLLATE 'utf8mb4_0900_ai_ci';
SELECT 'a'='á' AS ai, 'a'='A' AS ci, 'A'='á' AS ai_ci FROM t_duckdb;
ai	ci	ai_ci
1	1	1
