include/master-slave.inc
Warnings:
Note	####	Sending passwords in plain text without SSL/TLS is extremely insecure.
Note	####	Storing MySQL user name or password information in the connection metadata repository is not secure and is therefore not recommended. Please consider using the USER and PASSWORD connection options for START REPLICA; see the 'START REPLICA Syntax' in the MySQL Manual for more information.
[connection master]
[connection master]
CREATE TABLE t1 (id INT PRIMARY KEY, col1 INT) ENGINE=DuckDB;
CREATE TABLE t2 (id INT PRIMARY KEY, col1 INT) ENGINE=DuckDB;
SET @deault_duckdb_dml_in_batch = @@global.duckdb_dml_in_batch;
SET GLOBAL duckdb_dml_in_batch = 0;
[connection slave]
SET @deault_duckdb_dml_in_batch = @@global.duckdb_dml_in_batch;
SET GLOBAL duckdb_dml_in_batch = 0;

1. Due to log_slave_updates = 0 on the slave, 
the slave will not record any binlog.

[connection master]
INSERT INTO t1 VALUES (1, 1), (2, 2), (3, 3), (4, 4);
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t1;
id	col1
1	1
2	2
3	3
4	4
SELECT * FROM t2;
id	col1
1	1
2	2
3	3
4	4
include/rpl_sync.inc
[connection slave]
SELECT * FROM t1;
id	col1
1	1
2	2
3	3
4	4
SELECT * FROM t2;
id	col1
1	1
2	2
3	3
4	4
include/show_binlog_events.inc
Log_name	Pos	Event_type	Server_id	End_log_pos	Info
[connection master]
UPDATE t1 SET col1 = col1 + 1;
UPDATE t1 SET col1 = col1 + 1 WHERE id in (SELECT id FROM t2);
UPDATE t1 SET col1 = col1 + 1 WHERE id = (SELECT MAX(id) FROM t2);
SELECT * FROM t1;
id	col1
1	3
2	4
3	5
4	7
include/rpl_sync.inc
[connection slave]
SELECT * FROM t1;
id	col1
1	3
2	4
3	5
4	7
include/show_binlog_events.inc
Log_name	Pos	Event_type	Server_id	End_log_pos	Info
[connection master]
DELETE FROM t1 WHERE id = 3;
DELETE FROM t1 WHERE id = (SELECT MAX(id) FROM t2);
DELETE FROM t1 WHERE id in (SELECT id + 1 FROM t2);
SELECT * FROM t1;
id	col1
1	3
include/rpl_sync.inc
[connection slave]
SELECT * FROM t1;
id	col1
1	3
include/show_binlog_events.inc
Log_name	Pos	Event_type	Server_id	End_log_pos	Info

2. If sql_log_bin is set to 0 on the master, 
the master will not record any binlog.

[connection master]
DELETE FROM t1;
DELETE FROM t2;
SET sql_log_bin = 0;
[connection master]
INSERT INTO t1 VALUES (1, 1), (2, 2), (3, 3), (4, 4);
INSERT INTO t2 SELECT * FROM t1;
UPDATE t1 SET col1 = col1 + 1;
UPDATE t1 SET col1 = col1 + 1 WHERE id in (SELECT id FROM t2);
UPDATE t1 SET col1 = col1 + 1 WHERE id = (SELECT MAX(id) FROM t2);
DELETE FROM t1 WHERE id = 3;
DELETE FROM t1 WHERE id = (SELECT MAX(id) FROM t2);
DELETE FROM t1 WHERE id in (SELECT id + 1 FROM t2);
SELECT * FROM t1;
id	col1
1	3
SELECT * FROM t2;
id	col1
1	1
2	2
3	3
4	4
include/rpl_sync.inc
[connection slave]
include/show_binlog_events.inc
Log_name	Pos	Event_type	Server_id	End_log_pos	Info
SELECT * FROM t1;
id	col1
SELECT * FROM t2;
id	col1
[connection master]
SET sql_log_bin = 1;
DROP TABLE t1;
DROP TABLE t2;
SET GLOBAL duckdb_dml_in_batch = @deault_duckdb_dml_in_batch;
[connection slave]
SET GLOBAL duckdb_dml_in_batch = @deault_duckdb_dml_in_batch;
include/rpl_end.inc
