#
# 0) PREPARE SCRIPT
#
#
# 1) CREATE TABLE WITH GENERATED COLUMNS WITH DUCKDB
#
CREATE TABLE t1(id INT PRIMARY KEY, a INT, b INT,
c INT GENERATED ALWAYS AS (a + b) VIRTUAL,
d VARCHAR(1000) GENERATED ALWAYS AS (CONCAT(`a`, `b`)) STORED,
e VARCHAR(1000) GENERATED ALWAYS AS ('str') VIRTUAL,
j_val1 INT GENERATED ALWAYS AS (JSON_EXTRACT(`content`,_utf8mb4'$.val1')) STORED,
content text CHARACTER SET utf8mb4,
j_val2 VARCHAR(100) GENERATED ALWAYS AS (JSON_EXTRACT(`content`,_utf8mb4'$.val2')) VIRTUAL,
j_val3 decimal(38,20) GENERATED ALWAYS AS (JSON_EXTRACT(`content`,_utf8mb4'$.val3')) STORED
) ENGINE = DUCKDB;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int NOT NULL,
  `a` int DEFAULT NULL,
  `b` int DEFAULT NULL,
  `c` int GENERATED ALWAYS AS ((`a` + `b`)) VIRTUAL,
  `d` varchar(1000) GENERATED ALWAYS AS (concat(`a`,`b`)) STORED,
  `e` varchar(1000) GENERATED ALWAYS AS (_utf8mb4'str') VIRTUAL,
  `j_val1` int GENERATED ALWAYS AS (json_extract(`content`,_utf8mb4'$.val1')) STORED,
  `content` text CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci,
  `j_val2` varchar(100) GENERATED ALWAYS AS (json_extract(`content`,_utf8mb4'$.val2')) VIRTUAL,
  `j_val3` decimal(38,20) GENERATED ALWAYS AS (json_extract(`content`,_utf8mb4'$.val3')) STORED,
  PRIMARY KEY (`id`)
) ENGINE=DUCKDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
CALL dbms_duckdb.query("SELECT table_name, column_name, column_default FROM information_schema.columns WHERE table_name = 't1'");
RESULT
table_name	column_name	column_default	
VARCHAR	VARCHAR	VARCHAR	
[ Rows: 10]
t1	id	NULL
t1	a	NULL
t1	b	NULL
t1	c	CAST((a + b) AS INTEGER)
t1	d	CAST(concat(a, b) AS VARCHAR)
t1	e	CAST('str' AS VARCHAR)
t1	j_val1	CAST(json_extract("content", '$.val1') AS INTEGER)
t1	content	NULL
t1	j_val2	CAST(json_extract("content", '$.val2') AS VARCHAR)
t1	j_val3	CAST(json_extract("content", '$.val3') AS DECIMAL(38,20))


#
# 2) CONVERT TO INNODB
#
INSERT INTO t1(id, a, b, content) VALUES(1, 2, 3, '{"val1":1,"val2":"name_001","val3":1.01}');
ALTER TABLE t1 ENGINE = InnoDB;
SHOW CREATE TABLE t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `id` int NOT NULL,
  `a` int DEFAULT NULL,
  `b` int DEFAULT NULL,
  `c` int GENERATED ALWAYS AS ((`a` + `b`)) VIRTUAL,
  `d` varchar(1000) GENERATED ALWAYS AS (concat(`a`,`b`)) STORED,
  `e` varchar(1000) GENERATED ALWAYS AS (_utf8mb4'str') VIRTUAL,
  `j_val1` int GENERATED ALWAYS AS (json_extract(`content`,_utf8mb4'$.val1')) STORED,
  `content` text CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci,
  `j_val2` varchar(100) GENERATED ALWAYS AS (json_extract(`content`,_utf8mb4'$.val2')) VIRTUAL,
  `j_val3` decimal(38,20) GENERATED ALWAYS AS (json_extract(`content`,_utf8mb4'$.val3')) STORED,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci
CALL dbms_duckdb.query("SELECT table_name, column_name, column_default FROM information_schema.columns WHERE table_name = 't1'");
RESULT
table_name	column_name	column_default	
VARCHAR	VARCHAR	VARCHAR	
[ Rows: 0]


