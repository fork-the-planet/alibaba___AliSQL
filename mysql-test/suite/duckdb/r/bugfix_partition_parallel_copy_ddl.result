#
# Bugfix: Crash during parallel copy ddl for partition table.
#
CREATE TABLE `t_p_bugfix` (
`id` bigint NOT NULL,
`product_date` date NOT NULL,
`product_order` tinyint NOT NULL,
PRIMARY KEY (`id`,`product_date`,`product_order`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb3 COMMENT='服务专用维度表'
/*!50500 PARTITION BY RANGE  COLUMNS(product_date)
(PARTITION p20231001 VALUES LESS THAN ('2023-10-02') ENGINE = InnoDB,
PARTITION p20231002 VALUES LESS THAN ('2023-10-03') ENGINE = InnoDB,
PARTITION p_future VALUES LESS THAN (MAXVALUE) ENGINE = InnoDB) */;
