CREATE TABLE t1 (id INT PRIMARY KEY, col1 INT) ENGINE=DuckDB;
CREATE VIEW v1 AS SELECT * FROM t1;
CREATE ALGORITHM=MERGE VIEW v2 AS SELECT * FROM v1;
CREATE ALGORITHM=TEMPTABLE VIEW v3 AS SELECT * FROM v1;
CREATE VIEW v4(c1, c2) AS SELECT * FROM t1;
CREATE VIEW v5 AS SELECT MAX(id) FROM t1 GROUP BY col1;
CREATE ALGORITHM=MERGE VIEW v6 AS SELECT MAX(id) FROM t1 GROUP BY col1;
Warnings:
