SET duckdb_sql_normalization = on;
--------------------------
1. Supports binary strings in '0x' format.
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1);
SELECT 0xFFFF FROM t1;
0xFFFF
˙˙
DROP TABLE t1;
--------------------------
2. Date functions support STRING_LITERAL and VARCHAR as input.
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1);
SELECT LAST_DAY('2025-12-25') FROM t1;
LAST_DAY('2025-12-25')
2025-12-31
SELECT DATE_FORMAT('2025-12-25', '%W %M %Y') FROM t1;
DATE_FORMAT('2025-12-25', '%W %M %Y')
Thursday December 2025
SELECT TIME_FORMAT('12:25:30', '%H %i %s') FROM t1;
TIME_FORMAT('12:25:30', '%H %i %s')
12 25 30
SELECT DATE_ADD('2025-12-25', INTERVAL 1 DAY)
, DATE_ADD('2025-12-25', INTERVAL 1 SECOND)
, DATE_ADD('2025-12-25 10:47:30', INTERVAL 1 DAY)
, DATE_ADD('2025-12-25 10:47:30', INTERVAL 1 SECOND)
FROM t1;
DATE_ADD('2025-12-25', INTERVAL 1 DAY)	DATE_ADD('2025-12-25', INTERVAL 1 SECOND)	DATE_ADD('2025-12-25 10:47:30', INTERVAL 1 DAY)	DATE_ADD('2025-12-25 10:47:30', INTERVAL 1 SECOND)
2025-12-26	2025-12-25 00:00:01	2025-12-26 10:47:30	2025-12-25 10:47:31
SELECT EXTRACT(YEAR FROM '2025-12-25')
, EXTRACT(SECOND FROM '10:47:30')
, EXTRACT(YEAR FROM '2025-12-25 10:47:30')
, EXTRACT(SECOND FROM '2025-12-25 10:47:30')
FROM t1;
EXTRACT(YEAR FROM '2025-12-25')	EXTRACT(SECOND FROM '10:47:30')	EXTRACT(YEAR FROM '2025-12-25 10:47:30')	EXTRACT(SECOND FROM '2025-12-25 10:47:30')
2025	30	2025	30
SELECT ADDTIME('2007-12-31 23:59:59.999999', '1 1:1:1.000002'), ADDTIME('01:00:00.999999', '02:00:00.999998') FROM t1;
ADDTIME('2007-12-31 23:59:59.999999', '1 1:1:1.000002')	ADDTIME('01:00:00.999999', '02:00:00.999998')
2008-01-02 01:01:01.000001	03:00:01.999997
SELECT TIMESTAMPDIFF(MONTH,'2003-02-01','2003-05-01') FROM t1;
TIMESTAMPDIFF(MONTH,'2003-02-01','2003-05-01')
3
SELECT HOUR('10:47:30'), MINUTE('10:47:30')
, SECOND('10:47:30'), MICROSECOND('10:47:30')
, HOUR('2025-12-25 10:47:30'), MINUTE('2025-12-25 10:47:30')
, SECOND('2025-12-25 10:47:30'), MICROSECOND('2025-12-25 10:47:30')
, DAYNAME('2025-12-25 10:47:30'), WEEK('2025-12-25 10:47:30')
, DAYOFYEAR('2025-12-25 10:47:30'), QUARTER('2025-12-25 10:47:30')
, YEAR('2025-12-25 10:47:30'), MONTH('2025-12-25 10:47:30')
FROM t1;
HOUR('10:47:30')	MINUTE('10:47:30')	SECOND('10:47:30')	MICROSECOND('10:47:30')	HOUR('2025-12-25 10:47:30')	MINUTE('2025-12-25 10:47:30')	SECOND('2025-12-25 10:47:30')	MICROSECOND('2025-12-25 10:47:30')	DAYNAME('2025-12-25 10:47:30')	WEEK('2025-12-25 10:47:30')	DAYOFYEAR('2025-12-25 10:47:30')	QUARTER('2025-12-25 10:47:30')	YEAR('2025-12-25 10:47:30')	MONTH('2025-12-25 10:47:30')
10	47	30	0	10	47	30	0	Thursday	51	359	4	2025	12
SELECT CONVERT_TZ('2025-12-25 10:47:30', 'GMT', 'Asia/Shanghai') FROM t1;
CONVERT_TZ('2025-12-25 10:47:30', 'GMT', 'Asia/Shanghai')
2025-12-25 18:47:30
SET timestamp = 1753226301;
SELECT UNIX_TIMESTAMP('2025-12-25 10:47:30'), UNIX_TIMESTAMP('2025-12-25'), UNIX_TIMESTAMP() FROM t1;
UNIX_TIMESTAMP('2025-12-25 10:47:30')	UNIX_TIMESTAMP('2025-12-25')	UNIX_TIMESTAMP()
1766648850	1766610000	1753226301
SET timestamp = default;
CREATE TABLE t2 (id INT PRIMARY KEY, date_char VARCHAR(100), time_char VARCHAR(100), timestamp_char VARCHAR(100)) ENGINE=DuckDB;
INSERT INTO t2 VALUES (1, '2025-12-25', '10:47:30', '2025-12-25 10:47:30');
SELECT LAST_DAY(date_char), LAST_DAY(timestamp_char)
FROM t2;
LAST_DAY(date_char)	LAST_DAY(timestamp_char)
2025-12-31	2025-12-31
SELECT DATE_FORMAT(date_char, '%W %M %Y')
, DATE_FORMAT(timestamp_char, '%W %M %Y %H %i %s')
FROM t2;
DATE_FORMAT(date_char, '%W %M %Y')	DATE_FORMAT(timestamp_char, '%W %M %Y %H %i %s')
Thursday December 2025	Thursday December 2025 10 47 30
SELECT TIME_FORMAT(time_char, '%H %i %s')
FROM t2;
TIME_FORMAT(time_char, '%H %i %s')
10 47 30
SELECT EXTRACT(YEAR FROM date_char), EXTRACT(SECOND FROM time_char), EXTRACT(YEAR FROM timestamp_char), EXTRACT(SECOND FROM timestamp_char)
FROM t2;
EXTRACT(YEAR FROM date_char)	EXTRACT(SECOND FROM time_char)	EXTRACT(YEAR FROM timestamp_char)	EXTRACT(SECOND FROM timestamp_char)
2025	30	2025	30
SELECT HOUR(time_char), MINUTE(time_char)
, SECOND(time_char), MICROSECOND(time_char)
, HOUR(timestamp_char), MINUTE(timestamp_char)
, SECOND(timestamp_char), MICROSECOND(timestamp_char)
, DAYNAME(timestamp_char), WEEK(timestamp_char)
, DAYOFYEAR(timestamp_char), QUARTER(timestamp_char)
, YEAR(timestamp_char), MONTH(timestamp_char)
FROM t2;
HOUR(time_char)	MINUTE(time_char)	SECOND(time_char)	MICROSECOND(time_char)	HOUR(timestamp_char)	MINUTE(timestamp_char)	SECOND(timestamp_char)	MICROSECOND(timestamp_char)	DAYNAME(timestamp_char)	WEEK(timestamp_char)	DAYOFYEAR(timestamp_char)	QUARTER(timestamp_char)	YEAR(timestamp_char)	MONTH(timestamp_char)
10	47	30	0	10	47	30	0	Thursday	51	359	4	2025	12
SELECT CONVERT_TZ(timestamp_char, 'GMT', 'Asia/Shanghai') FROM t2;
CONVERT_TZ(timestamp_char, 'GMT', 'Asia/Shanghai')
2025-12-25 18:47:30.000000
SET timestamp = 1753226301;
SELECT UNIX_TIMESTAMP(timestamp_char), UNIX_TIMESTAMP(date_char), UNIX_TIMESTAMP() FROM t2;
UNIX_TIMESTAMP(timestamp_char)	UNIX_TIMESTAMP(date_char)	UNIX_TIMESTAMP()
1766648850	1766610000	1753226301
SET timestamp = default;
DROP TABLE t1;
DROP TABLE t2;
--------------------------
3. Support interval expr unit
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1);
SELECT DATE_ADD('2025-12-25', INTERVAL -1 DAY) FROM t1;
DATE_ADD('2025-12-25', INTERVAL -1 DAY)
2025-12-24
DROP TABLE t1;
--------------------------
4. Count multi column
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY, col1 INT, col2 INT) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1, 1, 1), (2, 1, 1);
SELECT COUNT(DISTINCT col1, col2) FROM t1;
COUNT(DISTINCT col1, col2)
1
DROP TABLE t1;
CREATE TABLE t1 (
id INT PRIMARY KEY,
col1 INT,
col2 VARCHAR(256),
col3 VARCHAR(256)
) ENGINE = DuckDB;
INSERT INTO t1
VALUES (1, 1, 'ab', 'c'),
(2, 1, 'a', 'bc'),
(3, 1, NULL, 'd'),
(4, 1, 'd', NULL),
(5, 1, NULL, NULL),
(6, 1, '0', '0'),
(7, 2, 'ab', 'c'),
(8, 2, 'a', 'bc'),
(9, 2, NULL, 'd'),
(10, 2, 'd', NULL),
(11, 2, '0', '0'),
(12, 2, NULL, NULL),
(13, 2, '0', '0');
SELECT COUNT(DISTINCT col2, col3) FROM t1;
COUNT(DISTINCT col2, col3)
3
SELECT COUNT(DISTINCT col2, 'a') FROM t1;
COUNT(DISTINCT col2, 'a')
4
SELECT COUNT(DISTINCT col2, col3) FROM t1 GROUP BY col1;
COUNT(DISTINCT col2, col3)
3
3
SELECT COUNT(DISTINCT col2, 'a') FROM t1 GROUP BY col1;
COUNT(DISTINCT col2, 'a')
4
4
DROP TABLE t1;
--------------------------
5. Group_concat
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY, col1 INT, col2 INT) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1, 1, 1), (2, 1, 1), (3, 0, 2);
SELECT GROUP_CONCAT(col1, col2 ORDER BY col1 SEPARATOR ' ') FROM t1;
GROUP_CONCAT(col1, col2 ORDER BY col1 SEPARATOR ' ')
02 11 11
SELECT GROUP_CONCAT(col1, col2 ORDER BY col1 SEPARATOR ' ') FROM t1;
GROUP_CONCAT(col1, col2 ORDER BY col1 SEPARATOR ' ')
02 11 11
SELECT GROUP_CONCAT(DISTINCT col1, col2 SEPARATOR ' ') in ('11 02', '02 11') FROM t1;
GROUP_CONCAT(DISTINCT col1, col2 SEPARATOR ' ') in ('11 02', '02 11')
1
DROP TABLE t1;
CREATE TABLE t1 (
id INT PRIMARY KEY,
col1 INT,
col2 VARCHAR(256),
col3 VARCHAR(256)
) ENGINE = DuckDB;
INSERT INTO t1
VALUES (1, 1, 'ab', 'c'),
(2, 1, 'a', 'bc'),
(3, 1, NULL, 'd'),
(4, 1, 'd', NULL),
(5, 1, NULL, NULL),
(6, 1, '0', '0'),
(7, 2, 'ab', 'c'),
(8, 2, 'a', 'bc'),
(9, 2, NULL, 'd'),
(10, 2, 'd', NULL),
(11, 2, '0', '0'),
(12, 2, NULL, NULL),
(13, 2, '0', '0');
SELECT GROUP_CONCAT(col2, 'a' ORDER BY 1) FROM t1;
GROUP_CONCAT(col2, 'a' ORDER BY 1)
0a,0a,0a,aa,aa,aba,aba,da,da
SELECT GROUP_CONCAT(col2, 'a' ORDER BY 1, 2) FROM t1;
GROUP_CONCAT(col2, 'a' ORDER BY 1, 2)
0a,0a,0a,aa,aa,aba,aba,da,da
SELECT GROUP_CONCAT(col2, col3 ORDER BY col2, col3) FROM t1;
GROUP_CONCAT(col2, col3 ORDER BY col2, col3)
00,00,00,abc,abc,abc,abc
SELECT GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 1, 2) FROM t1;
GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 1, 2)
00,abc,abc
SELECT GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 2, 1 SEPARATOR ' ') FROM t1;
GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 2, 1 SEPARATOR ' ')
00 abc abc
SELECT GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 1, 2 SEPARATOR ' ') FROM t1;
GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 1, 2 SEPARATOR ' ')
00 abc abc
SELECT GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 2, 1 SEPARATOR ' ') FROM t1;
GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 2, 1 SEPARATOR ' ')
00 abc abc
SELECT GROUP_CONCAT(col2, 'a' ORDER BY 1) FROM t1 GROUP BY col1;
GROUP_CONCAT(col2, 'a' ORDER BY 1)
0a,aa,aba,da
0a,0a,aa,aba,da
SELECT GROUP_CONCAT(col2, 'a' ORDER BY 1, 2) FROM t1 GROUP BY col1;
GROUP_CONCAT(col2, 'a' ORDER BY 1, 2)
0a,aa,aba,da
0a,0a,aa,aba,da
SELECT GROUP_CONCAT(col2, col3 ORDER BY col2, col3) FROM t1 GROUP BY col1;
GROUP_CONCAT(col2, col3 ORDER BY col2, col3)
00,abc,abc
00,00,abc,abc
SELECT GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 1, 2) FROM t1 GROUP BY col1;
GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 1, 2)
00,abc,abc
00,abc,abc
SELECT GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 2, 1 SEPARATOR ' ') FROM t1 GROUP BY col1;
GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 2, 1 SEPARATOR ' ')
00 abc abc
00 abc abc
SELECT GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 1, 2 SEPARATOR ' ') FROM t1 GROUP BY col1;
GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 1, 2 SEPARATOR ' ')
00 abc abc
00 abc abc
SELECT GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 2, 1 SEPARATOR ' ') FROM t1 GROUP BY col1;
GROUP_CONCAT(DISTINCT col2, col3 ORDER BY 2, 1 SEPARATOR ' ')
00 abc abc
00 abc abc
DROP TABLE t1;
--------------------------
6. Priority of symbol associativity
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY, col1 JSON) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1, '{"a":"b"}');
SELECT 1 = 1 and col1->>'$.a' = 'b', 1!=-1, 1--1 FROM t1;
1 = 1 and col1->>'$.a' = 'b'	1!=-1	1--1
1	1	2
DROP TABLE t1;
--------------------------
7. Alias
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
SELECT id 'id' FROM t1;
id
SELECT id "id" FROM t1;
id
SELECT id time FROM t1;
time
DROP TABLE t1;
--------------------------
8. Comparison of year type and numeric literal
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY, col1 year) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1, 1970);
SELECT * FROM t1 WHERE col1 = 70;
id	col1
1	1970
DROP TABLE t1;
--------------------------
9. Mixture of implicit join and explicit join
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY, col1 year) ENGINE=DuckDB;
SELECT * FROM t1 d1 JOIN (t1 d2, t1 d3);
id	col1	id	col1	id	col1
DROP TABLE t1;
--------------------------
10. Supports Dual
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1);
SELECT 1 AS id FROM DUAL;
id
1
SELECT 1 AS id FROM DUAL WHERE 1 = -1;
id
SELECT * FROM t1 WHERE id in (SELECT 1 FROM DUAL WHERE 1=0);
id
SELECT * FROM t1 WHERE id in (SELECT 1 FROM DUAL WHERE 1=1);
id
1
DROP TABLE t1;
--------------------------
11. When string is converted to signed, it will be truncated.
--------------------------
CREATE TABLE t1 (id VARCHAR(100) PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1
VALUES ('-9223372036854775808.4'),
('-9223372036854775808.5'),
('-9223372036854775808.6'),
('0.4'),
('0.5'),
('0.6'),
('9223372036854775807.4'),
('9223372036854775807.5'),
('9223372036854775807.6'),
('5.5.5'),
('5.5e5'),
('5'),
('e5');
SELECT CAST(id AS SIGNED) FROM t1;
CAST(id AS SIGNED)
-9223372036854775808
-9223372036854775808
-9223372036854775808
0
0
0
9223372036854775807
9223372036854775807
9223372036854775807
5
5
5
0
DROP TABLE t1;
--------------------------
12. Index hint
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY, col1 INT, KEY index_col1(col1)) ENGINE=DuckDB;
Warnings:
Warning	7505	[DuckDB] Index 'index_col1' is removed.
INSERT INTO t1 VALUES (1, 1);
SELECT * FROM t1 USE INDEX (PRIMARY);
id	col1
1	1
SELECT * FROM t1 IGNORE INDEX (PRIMARY);
id	col1
1	1
SELECT * FROM t1 FORCE INDEX (PRIMARY);
id	col1
1	1
SELECT * FROM t1 USE INDEX (index_col1);
id	col1
1	1
Warnings:
Warning	1176	Key 'index_col1' doesn't exist in table 't1'
SELECT * FROM t1 IGNORE INDEX (index_col1);
id	col1
1	1
Warnings:
Warning	1176	Key 'index_col1' doesn't exist in table 't1'
SELECT * FROM t1 FORCE INDEX (index_col1);
id	col1
1	1
Warnings:
Warning	1176	Key 'index_col1' doesn't exist in table 't1'
SELECT * FROM t1 USE INDEX (index_col2);
id	col1
1	1
Warnings:
Warning	1176	Key 'index_col2' doesn't exist in table 't1'
SELECT * FROM t1 IGNORE INDEX (index_col2);
id	col1
1	1
Warnings:
Warning	1176	Key 'index_col2' doesn't exist in table 't1'
SELECT * FROM t1 FORCE INDEX (index_col2);
id	col1
1	1
Warnings:
Warning	1176	Key 'index_col2' doesn't exist in table 't1'
DROP TABLE t1;
--------------------------
13. Convert
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY, col1 VARCHAR(20) CHARSET utf8mb3) ENGINE=DuckDB;
Warnings:
Warning	1287	'utf8mb3' is deprecated and will be removed in a future release. Please use utf8mb4 instead
INSERT INTO t1 VALUES (1, 'abc');
SELECT CONVERT(col1 USING utf8mb4) FROM t1;
CONVERT(col1 USING utf8mb4)
abc
DROP TABLE t1;
CREATE TABLE t1 (id INT PRIMARY KEY, col1 VARCHAR(20) CHARSET latin1) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1, 'ĂşĂş');
SELECT * FROM t1 WHERE col1 = CONCAT('Ăş', 'Ăş');
id	col1
1	ĂşĂş
DROP TABLE t1;
--------------------------
14. Member of
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1);
SELECT 17 MEMBER OF('[23, "abc", 17, "ab", 10]') FROM t1;
17 MEMBER OF('[23, "abc", 17, "ab", 10]')
1
SELECT 'ab' MEMBER OF('[23, "abc", 17, "ab", 10]') FROM t1;
'ab' MEMBER OF('[23, "abc", 17, "ab", 10]')
1
SELECT 7 MEMBER OF('[23, "abc", 17, "ab", 10]') FROM t1;
7 MEMBER OF('[23, "abc", 17, "ab", 10]')
0
SELECT 'a' MEMBER OF('[23, "abc", 17, "ab", 10]') FROM t1;
'a' MEMBER OF('[23, "abc", 17, "ab", 10]')
0
SELECT 17 MEMBER OF('[23, "abc", "17", "ab", 10]'), "17" MEMBER OF('[23, "abc", 17, "ab", 10]') FROM t1;
17 MEMBER OF('[23, "abc", "17", "ab", 10]')	"17" MEMBER OF('[23, "abc", 17, "ab", 10]')
0	0
SELECT CAST('[4,5]' AS JSON) MEMBER OF('[[3,4],[4,5]]') FROM t1;
CAST('[4,5]' AS JSON) MEMBER OF('[[3,4],[4,5]]')
1
SELECT '[4,5]' MEMBER OF('[[3,4],[4,5]]') FROM t1;
'[4,5]' MEMBER OF('[[3,4],[4,5]]')
0
SELECT '\"' MEMBER OF('["\\\""]'), '"' MEMBER OF('["\\\""]') FROM t1;
'\"' MEMBER OF('["\\\""]')	'"' MEMBER OF('["\\\""]')
1	1
DROP TABLE t1;
--------------------------
1. GROUP BY ... WITH ROLLUP ORDER BY ...
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
CREATE TABLE t2 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1), (2);
INSERT INTO t2 VALUES (2), (1);
SELECT t1.id, t2.id FROM t1, t2 GROUP BY t1.id, t2.id WITH ROLLUP ORDER BY t1.id, t2.id;
id	id
NULL	NULL
1	NULL
1	1
1	2
2	NULL
2	1
2	2
DROP TABLE t1, t2;
--------------------------
2. The string contains single quotes
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1);
SELECT '''', '\'' FROM t1;
'	'
'	'
DROP TABLE t1;
--------------------------
3. Empty alias
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1);
SELECT 1 '' FROM t1;

1
DROP TABLE t1;
--------------------------
4. Date cast functions
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1);
SELECT CAST('2025-12-25 12:25:40' AS DATETIME(4)) FROM t1;
CAST('2025-12-25 12:25:40' AS DATETIME(4))
2025-12-25 12:25:40.0000
SELECT CAST('12:25:40' AS TIME(4)) FROM t1;
CAST('12:25:40' AS TIME(4))
12:25:40.0000
DROP TABLE t1;
--------------------------
5. bin/oct functions
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1);
SELECT BIN(2025), OCT(2025) FROM t1;
BIN(2025)	OCT(2025)
11111101001	3751
DROP TABLE t1;
--------------------------
6. String cast functions
--------------------------
CREATE TABLE t1 (id INT PRIMARY KEY) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1);
SELECT CAST('abc' AS CHAR), CAST('abc' AS BINARY) FROM t1;
CAST('abc' AS CHAR)	CAST('abc' AS BINARY)
abc	abc
DROP TABLE t1;
