--source include/master-slave.inc
--source include/have_binlog_format_row.inc

--echo ###########################################################################
--echo # 0. Prepare
--echo ###########################################################################
--source include/rpl_connection_master.inc
CREATE TABLE t1 (
    id BIGINT NOT NULL,
    c0 VARCHAR(20) NOT NULL,
    c1 CHAR(10) DEFAULT 'duckdb',
    c2 DECIMAL(5,2),
    PRIMARY KEY(id)
) ENGINE=InnoDB;
SHOW CREATE TABLE t1;

--source include/rpl_sync.inc
--source include/rpl_connection_slave.inc
SHOW CREATE TABLE t1;

--echo ###########################################################################
--echo # 1. Test Insert
--echo ###########################################################################
--source include/rpl_connection_master.inc
INSERT INTO t1 (id, c0, c1, c2) VALUES
(1, 'abc', NULL, 1.23),
(2, 'd', NULL, 3.8),
(3, 'efg', 'RSA', 5.2),
(4, 'hijk', NULL, 6),
(5, 'lmn', 'RSA', 10.5);

--source include/rpl_sync.inc
--let $rpl_diff_statement = SELECT id, c0, c1, c2 FROM test.t1 ORDER BY id;
--source include/rpl_diff.inc

--let $assert_file = $MYSQLTEST_VARDIR/log/mysqld.2.err
--let $assert_text = Check there are 1 (5 / 3) TRUNCATE SQL
--let $assert_select = TRUNCATE main.`test_rds_buf_t1`
--let $assert_count = 1
--source include/assert_grep.inc
--exec echo "" > $MYSQLTEST_VARDIR/log/mysqld.2.err

--echo ###########################################################################
--echo # 2. Test Update
--echo ###########################################################################
--source include/rpl_connection_master.inc
UPDATE t1 SET c2 = c2 + 3;

--source include/rpl_sync.inc
--let $rpl_diff_statement = SELECT id, c0, c1, c2 FROM test.t1 ORDER BY id;
--source include/rpl_diff.inc

--let $assert_text = Check there are 3 (5 * 2 / 3) TRUNCATE SQL
--let $assert_count = 3
--source include/assert_grep.inc
--exec echo "" > $MYSQLTEST_VARDIR/log/mysqld.2.err

--echo ###########################################################################
--echo # 3. Test Mix Transaction
--echo ###########################################################################
--source include/rpl_connection_master.inc
BEGIN;
DELETE FROM t1 WHERE id=3;
UPDATE t1 SET c1='zzzzzz' WHERE id=1;
INSERT INTO t1 (id, c0) VALUES (7, 'hhhhh');
COMMIT;

--source include/rpl_sync.inc
--let $rpl_diff_statement = SELECT id, c0, c1, c2 FROM test.t1 ORDER BY id;
--source include/rpl_diff.inc

--let $assert_text = Check there are 1 ((1 + 2 + 1) / 3) TRUNCATE SQL
--let $assert_count = 1
--source include/assert_grep.inc
--exec echo "" > $MYSQLTEST_VARDIR/log/mysqld.2.err

--echo ###########################################################################
--echo # 4. Test Delete
--echo ###########################################################################
--source include/rpl_connection_master.inc
DELETE FROM t1;

--source include/rpl_sync.inc
--let $rpl_diff_statement = SELECT id, c0, c1, c2 FROM test.t1 ORDER BY id;
--source include/rpl_diff.inc

--let $assert_text = Check there are 1 (5 / 3) TRUNCATE SQL
--let $assert_count = 1
--source include/assert_grep.inc
--exec echo "" > $MYSQLTEST_VARDIR/log/mysqld.2.err

--echo ###########################################################################
--echo # Cleanup
--echo ###########################################################################
--source include/rpl_connection_master.inc
DROP TABLE t1;
--source include/rpl_sync.inc
--source include/rpl_end.inc
