CREATE TABLE t1 (id INT PRIMARY KEY, col1 INT) ENGINE=DuckDB;
CREATE VIEW v1 AS SELECT * FROM t1;
CREATE ALGORITHM=MERGE VIEW v2 AS SELECT * FROM v1;
CREATE ALGORITHM=TEMPTABLE VIEW v3 AS SELECT * FROM v1;
CREATE VIEW v4(c1, c2) AS SELECT * FROM t1;
CREATE VIEW v5 AS SELECT MAX(id) FROM t1 GROUP BY col1;
CREATE ALGORITHM=MERGE VIEW v6 AS SELECT MAX(id) FROM t1 GROUP BY col1;
CREATE ALGORITHM=TEMPTABLE VIEW v7 AS SELECT MAX(id) FROM t1 GROUP BY col1;
CREATE VIEW v8(max_id) AS SELECT MAX(id) FROM t1 GROUP BY col1;

INSERT INTO t1 VALUES (1, 1), (2, 2), (3, 1), (4, 2);

SET duckdb_sql_normalization = on;
SELECT * FROM v1;
SELECT * FROM v2;
SELECT * FROM v3;
SELECT * FROM v4;
SELECT * FROM v5;
SELECT * FROM v6;
SELECT * FROM v7;
SELECT * FROM v8;

SELECT * FROM v1 d1;
SELECT * FROM v2 d1;
SELECT * FROM v3 d1;
SELECT * FROM v4 d1;
SELECT * FROM v5 d1;
SELECT * FROM v6 d1;
SELECT * FROM v7 d1;
SELECT * FROM v8 d1;

SELECT col1 FROM v1;
SELECT c1 FROM v4;

SELECT * FROM v1, v5 WHERE v1.id = v5.`max(id)`;
SELECT * FROM v4, v8 WHERE v4.c1 = v8.max_id;

DROP VIEW v1, v2, v3, v4, v5, v6, v7, v8;
DROP TABLE t1;
