--source include/master-slave.inc
--source include/have_binlog_format_mixed.inc
--source include/rpl_connection_master.inc
CREATE TABLE t1 (id INT PRIMARY KEY, col1 INT) ENGINE=DuckDB;
CREATE TABLE t2 (id INT PRIMARY KEY, col1 INT) ENGINE=DuckDB;
SET @deault_duckdb_dml_in_batch = @@global.duckdb_dml_in_batch;
SET GLOBAL duckdb_dml_in_batch = 0;

--source include/rpl_connection_slave.inc
SET @deault_duckdb_dml_in_batch = @@global.duckdb_dml_in_batch;
SET GLOBAL duckdb_dml_in_batch = 0;

--echo
--echo 1. Due to log_slave_updates = 0 on the slave, 
--echo    the slave will not record any binlog.
--echo

--source include/rpl_connection_master.inc
INSERT INTO t1 VALUES (1, 1), (2, 2), (3, 3), (4, 4);
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t1;
SELECT * FROM t2;

--source include/rpl_sync.inc
--source include/rpl_connection_slave.inc
SELECT * FROM t1;
SELECT * FROM t2;
--source include/show_binlog_events.inc

--source include/rpl_connection_master.inc
UPDATE t1 SET col1 = col1 + 1;
UPDATE t1 SET col1 = col1 + 1 WHERE id in (SELECT id FROM t2);
UPDATE t1 SET col1 = col1 + 1 WHERE id = (SELECT MAX(id) FROM t2);
SELECT * FROM t1;

--source include/rpl_sync.inc
--source include/rpl_connection_slave.inc
SELECT * FROM t1;
--source include/show_binlog_events.inc

--source include/rpl_connection_master.inc
DELETE FROM t1 WHERE id = 3;
DELETE FROM t1 WHERE id = (SELECT MAX(id) FROM t2);
DELETE FROM t1 WHERE id in (SELECT id + 1 FROM t2);
SELECT * FROM t1;

--source include/rpl_sync.inc
--source include/rpl_connection_slave.inc
SELECT * FROM t1;
--source include/show_binlog_events.inc

--echo
--echo 2. If sql_log_bin is set to 0 on the master, 
--echo    the master will not record any binlog.
--echo

--source include/rpl_connection_master.inc
DELETE FROM t1;
DELETE FROM t2;
SET sql_log_bin = 0;

--source include/rpl_connection_master.inc
INSERT INTO t1 VALUES (1, 1), (2, 2), (3, 3), (4, 4);
INSERT INTO t2 SELECT * FROM t1;
UPDATE t1 SET col1 = col1 + 1;
UPDATE t1 SET col1 = col1 + 1 WHERE id in (SELECT id FROM t2);
UPDATE t1 SET col1 = col1 + 1 WHERE id = (SELECT MAX(id) FROM t2);
DELETE FROM t1 WHERE id = 3;
DELETE FROM t1 WHERE id = (SELECT MAX(id) FROM t2);
DELETE FROM t1 WHERE id in (SELECT id + 1 FROM t2);
SELECT * FROM t1;
SELECT * FROM t2;

--source include/rpl_sync.inc
--source include/rpl_connection_slave.inc
--source include/show_binlog_events.inc
SELECT * FROM t1;
SELECT * FROM t2;

--source include/rpl_connection_master.inc
SET sql_log_bin = 1;
DROP TABLE t1;
DROP TABLE t2;

SET GLOBAL duckdb_dml_in_batch = @deault_duckdb_dml_in_batch;
--source include/rpl_connection_slave.inc
SET GLOBAL duckdb_dml_in_batch = @deault_duckdb_dml_in_batch;
--source include/rpl_end.inc
