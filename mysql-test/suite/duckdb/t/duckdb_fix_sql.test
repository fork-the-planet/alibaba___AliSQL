CREATE TABLE t1 (id INT PRIMARY KEY, col1 VARCHAR(10));
INSERT INTO t1 VALUES (1, '1'), (2, '0'), (3, 'yes'), (4, 'no'), (5, 'true'), (6, 'false'), (7, '0.1'), (8, '0.0'), (9, '2.0');
