# Modify type conversion function from varchar to double
CREATE TABLE t1 (id INT PRIMARY KEY, col1 VARCHAR(10)) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1, '-'), (2, '--'), (3, '-a'), (4, '-1');
SELECT CAST(col1 AS DOUBLE) FROM t1;
SELECT SUM(col1) FROM t1;
DROP TABLE t1;

# Test duckdb_prefer_high_precision
CREATE TABLE t1 (id INT PRIMARY KEY, col1 DECIMAL(18, 2), col2 INT) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1, 9999999999999999.99, 99999999);
--error ER_DUCKDB_CLIENT
SELECT col1 * col1 FROM t1;
--error ER_DUCKDB_CLIENT
SELECT col2 * 1.00000000001 FROM t1;
--error ER_DUCKDB_CLIENT
SELECT col1 + col2 FROM t1;
SET duckdb_prefer_high_precision = true;
SELECT col1 * col1, col2 * 1.00000000001, col1 + col2 FROM t1;
DROP TABLE t1;

# Supports comparison of bit and boolean types
# Supports algebraic operations on bit type
CREATE TABLE t1 (id INT PRIMARY KEY, col1 BIT(64) DEFAULT b'111111110000000011111111') ENGINE=DuckDB;
INSERT INTO t1 VALUES (1, x'00'), (2, x'01'), (3, b'1111111111'), (4, x'00FF00FF00FF00FF');
INSERT INTO t1 (id) VALUES (5);
--exec $MYSQL test --binary-as-hex -e "SELECT col1, LENGTH(col1) FROM t1;"
--exec $MYSQL test --binary-as-hex -e "SELECT col1 FROM t1 WHERE col1 = true;"
--exec $MYSQL test --binary-as-hex -e "SELECT col1 FROM t1 WHERE col1 = false;"
--exec $MYSQL test --binary-as-hex -e "SELECT col1 FROM t1 WHERE col1;"
--exec $MYSQL test --binary-as-hex -e "SELECT col1 FROM t1 WHERE not col1;"
--exec $MYSQL test --binary-as-hex -e "SELECT col1 FROM t1 WHERE col1 = x'01';"
SELECT col1 + 1, col1 * 2 FROM t1;
SELECT id, col1 = 1, col1 > 1, col1 < 1 FROM t1;
DROP TABLE t1;

# concat blob
CREATE TABLE t1 (id INT PRIMARY KEY, col1 VARCHAR(10), col2 BLOB) ENGINE=DuckDB;
INSERT INTO t1 VALUES (1, 'abc', 0xFFFF);
--exec $MYSQL test --binary-as-hex -e "SELECT CONCAT(col1, col2) FROM t1;"
DROP TABLE t1;
