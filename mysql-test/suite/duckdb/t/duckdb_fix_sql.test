SELECT col1 > lower, col1 < higher, col1 BETWEEN lower AND higher
	, col1 = equal, col2 > lower
	, col2 < higher, col2 BETWEEN lower AND higher
	, col2 = equal,  col2 > lower
	, col2 < higher, col2 BETWEEN lower AND higher
	, col2 = equal,  col3 > lower
	, col3 < higher, col3 BETWEEN lower AND higher
	, col3 = equal, col4 > lower
	, col4 < higher, col4 BETWEEN lower AND higher
	, col4 = equal,  col5 > lower
	, col5 < higher, col5 BETWEEN lower AND higher
	, col5 = equal,  col6 > lower
	, col6 < higher, col6 BETWEEN lower AND higher
	, col6 = equal
FROM t1, t_int;

