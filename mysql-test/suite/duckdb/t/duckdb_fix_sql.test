SELECT CAST(col1 AS CHAR) like '%据%' FROM t1;
SELECT FROM_BASE64(TO_BASE64('数据库')), CAST(FROM_BASE64(TO_BASE64('数据库')) AS CHAR) LIKE '%据%' FROM t1 LIMIT 1;
ALTER TABLE t1 ENGINE=DuckDB;
SELECT CAST(col1 AS CHAR) FROM t1;
SELECT CAST(col1 AS CHAR) like '%据%' FROM t1;
SELECT FROM_BASE64(TO_BASE64('数据库')), CAST(FROM_BASE64(TO_BASE64('数据库')) AS CHAR) LIKE '%据%' FROM t1 LIMIT 1;

DROP TABLE t1;

