# Modify type conversion function from blob to varchar
CREATE TABLE t1 (id INT PRIMARY KEY, col1 BLOB);
INSERT INTO t1 VALUES (1, 0xFF), (2, 0x61), (3, 0xE695B0E68DAEE5BA93);
