# Allow order by non integer literal
CREATE TABLE t1 (id INT PRIMARY KEY, col1 int);
INSERT INTO t1 VALUES (1, 2), (2, 1);
SELECT * FROM t1 ORDER BY 'abc', '', 1.1, 2;
ALTER TABLE t1 ENGINE=DuckDB;
SELECT * FROM t1 ORDER BY 'abc', '', 1.1, 2;
DROP TABLE t1;

# Support comparison between numeric type and temporal type
CREATE TABLE t1 (
	id INT PRIMARY KEY,
	col1 DATE,
	col2 TIMESTAMP,
	col3 DATETIME,
	col4 TIME,
	col5 TIMESTAMP(6),
	col6 TIME(6)
);

CREATE TABLE t_int (
	id INT PRIMARY KEY,
	lower BIGINT,
	higher BIGINT,
	equal BIGINT
);

CREATE TABLE t_decimal (
	id INT PRIMARY KEY,
	lower DECIMAL(38, 10),
	higher DECIMAL(38, 10),
	equal DECIMAL(38, 10)
);

CREATE TABLE t_double (
	id INT PRIMARY KEY,
	lower DOUBLE,
	higher DOUBLE,
	equal DOUBLE
);

INSERT INTO t1 VALUES (1, '2020-01-01', '2020-01-01 12:00:00', '2020-01-01 12:00:00', '12:00:00', '2020-01-01 12:00:00.123456', '12:00:00.123456');

