#
# Case: It should increase binlog buffer automatically if it is
# too small.
################################################################
#
include/stop_slave_io.inc
[connection master]
SET GLOBAL persist_binlog_to_redo_size_limit = 10000000;
SELECT @@GLOBAL.persist_binlog_to_redo_size_limit;
@@GLOBAL.persist_binlog_to_redo_size_limit
10000000
SET GLOBAL wait_binlog_flush = OFF;
SET GLOBAL innodb_checkpoint_disabled = ON;
DROP TABLE t1;
CREATE TABLE t1(c1 varchar(20), c2 LONGTEXT) ENGINE=InnoDB;
SET debug_sync = "before_flush_binlog_cache SIGNAL insert1_before_flush
                  WAIT_FOR insert1_continue";
SET debug = "+d,crash_commit_after_sync_to_redo";
INSERT INTO t1 VALUES("insert1", "insert1");
[connection server_1]
SET debug_sync = "now WAIT_FOR insert1_before_flush";
INSERT INTO t1 VALUES("insert2", repeat("A", 9000000));
INSERT INTO t1 VALUES("insert3", repeat("B", 9000000));
INSERT INTO t1 VALUES("insert4", repeat("C", 9000000));
INSERT INTO t1 VALUES("insert5", repeat("D", 9000000));
INSERT INTO t1 VALUES("insert6", repeat("E", 9000000));
include/show_binlog_events.inc
SET debug_sync = "now SIGNAL insert1_continue";
