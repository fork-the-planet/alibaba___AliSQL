#
# Case: It can recovered correctly when binlog is disordered in redo
####################################################################
#
include/stop_slave_io.inc
[connection master]
SET GLOBAL innodb_checkpoint_disabled = ON;
DROP TABLE t1;
CREATE TABLE t1(c1 varchar(20)) ENGINE=InnoDB;
SET debug_sync = "before_flush_binlog_cache SIGNAL insert1_before_flush
                  WAIT_FOR insert1_continue";
INSERT INTO t1 VALUES("insert1");
[connection server_1]
SET debug_sync = "now WAIT_FOR insert1_before_flush";
SET debug_sync = "after_write_to_redo SIGNAL insert2_written_to_redo";
INSERT INTO t1 VALUES("insert2");
[connection server_1_1]
SET debug_sync = "now WAIT_FOR insert2_written_to_redo";
SET debug_sync = "before_flush_binlog_cache SIGNAL insert3_before_flush
                  WAIT_FOR insert3_continue";
INSERT INTO t1 VALUES("insert3");
SET debug_sync = "now WAIT_FOR insert3_before_flush";
SET debug_sync = "after_write_to_redo SIGNAL insert1_continue";
INSERT INTO t1 VALUES("insert4");
[connection master]
SET debug_sync = "now SIGNAL insert3_continue";
[connection server_1]
[connection server_1_2]
[connection server_1_1]
SET debug_sync = "before_flush_binlog_cache SIGNAL insert5_before_flush
                  WAIT_FOR insert5_continue";
INSERT INTO t1 VALUES("insert5");
[connection master]
SET debug_sync = "now WAIT_FOR insert5_before_flush";
SET debug_sync = "after_write_to_redo SIGNAL insert6_written_to_redo";
INSERT INTO t1 VALUES("insert6");
[connection server_1]
SET debug_sync = "now WAIT_FOR insert6_written_to_redo";
SET debug = "d,crash_commit_after_sync_to_redo";
INSERT INTO t1 VALUES("insert7");
ERROR HY000: Lost connection to MySQL server during query
[connection server_1_1]
ERROR HY000: Lost connection to MySQL server during query
