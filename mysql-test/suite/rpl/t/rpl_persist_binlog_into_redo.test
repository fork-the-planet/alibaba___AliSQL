################################################################################
# [Feature] Persist binlog into redo
#
# Binlog events of transactions are write into both binlog and redo log when
# commit. Thus we can relax the fsync operation on binlog. Since the lost binlog
# can be recovered from redo log.
#
# This test verify binlog is written to redo log correctly and that the binlog
# is generated and replicated correctly while the feature is enabled.
################################################################################
--source include/have_debug.inc
--source include/have_debug_sync.inc
--source include/have_binlog_format_row.inc
--source include/master-slave.inc

--echo #
--echo # Case: It should binlog and replicate well for basic operations
--echo #################################################################
--echo #
# The statements should not go through BGC, thus crash will not happen
SET debug = "+d,crash_after_flush_binlog";

CREATE TABLE t1(c1_my_test INT) ENGINE=InnoDB;

INSERT INTO t1 VALUES(1);
# It should binlog and replicate well after FLUSH BINARY LOGS
FLUSH BINARY LOGS;
INSERT INTO t1 VALUES(2);
--source include/sync_slave_sql_with_master.inc

# It should binlog and replicate well after reset master
--source include/rpl_reset.inc
--source include/rpl_connection_master.inc
INSERT INTO t1 VALUES(3);
DROP TABLE t1;
--source include/sync_slave_sql_with_master.inc

--echo #
--echo # Case: It should replicate well for the case more than
--echo #       one transactions in the buffer queue.
--echo ########################################################
--echo #
--source include/rpl_connection_master.inc
CREATE TABLE t1(c1_my_test INT) ENGINE=InnoDB;

SET debug_sync = "before_flush_binlog_cache SIGNAL insert1_ready
                  WAIT_FOR insert1_continue";
--send INSERT INTO t1 VALUES(100)

--let $rpl_connection_name = server_1
--source include/rpl_connection.inc
SET debug_sync = "now WAIT_FOR insert1_ready";
SET debug_sync = "after_write_to_redo SIGNAL insert2_ready
                  WAIT_FOR insert2_continue";
--send INSERT INTO t1 VALUES(101)

--let $rpl_connection_name = server_1_1
--source include/rpl_connection.inc
SET debug_sync = "now WAIT_FOR insert2_ready";
SET debug_sync = "now SIGNAL insert1_continue";
SET debug_sync = "now SIGNAL insert2_continue";

--source include/rpl_connection_master.inc
--reap
SET debug_sync = "now SIGNAL insert2_continue";

--let $rpl_connection_name = server_1
--source include/rpl_connection.inc
--reap

--source include/sync_slave_sql_with_master.inc

--echo #
--echo # Case: Big transactions are not be written into redo log
--echo ###########################################################
--echo #
--source include/rpl_connection_master.inc
CREATE TABLE t2(c1 INT, c2 LONGTEXT) ENGINE=InnoDB;
FLUSH LOGS;

--let $datadir = `SELECT @@datadir`
--let $binlog_file = query_get_value(SHOW MASTER STATUS, File, 1)
--copy_file $datadir/$binlog_file $datadir/binlog_for_recovery

SET debug_sync = "before_flush_binlog_cache SIGNAL insert1_ready
                  WAIT_FOR insert1_continue";
--send INSERT INTO t2 VALUES(1, "1")

--let $rpl_connection_name = server_1
--source include/rpl_connection.inc
SET debug_sync = "now WAIT_FOR insert1_ready";
--send INSERT INTO t2 VALUES(2, repeat('2', 2000000))

--let $rpl_connection_name = server_1_1
--source include/rpl_connection.inc

# Above insert is too large, it will go through BGC stages.
# In flush stage, it needs to wait until the async write queue is empty.
let $wait_condition=
    SELECT count(*) = 1 FROM information_schema.processlist
    WHERE state = "Waiting for binlog write queue empty";
--source include/wait_condition.inc

# It is a small INSERT, thus it should not go through bgc, so the debug_sync
# should not block it.
SET debug = "+d,crash_after_flush_binlog";

# When acquiring LOCK_log, It will be blocked by
# INSERT INTO t2 VALUES(2, repeat('2', 2000000))
--send INSERT INTO t2 VALUES(3, "3")

--let $rpl_connection_name = default
--source include/rpl_connection.inc
SET debug_sync = "now SIGNAL insert1_continue";

--source include/rpl_connection_master.inc
--reap

--let $rpl_connection_name = server_1
--source include/rpl_connection.inc
--reap

--let $rpl_connection_name = server_1_1
--source include/rpl_connection.inc
--reap
SET debug = "-d,crash_after_flush_binlog";

--source include/sync_slave_sql_with_master.inc

--echo #
--echo # Case: It should binlog and replicate well after a big transaction
--echo ####################################################################
--echo #
--source include/rpl_connection_master.inc
# When persist_binlog_to_redo is off, the statements will go though BGC. Thus
# crash will not happen
SET debug = "+d,crash_commit_after_sync_to_redo";
SET debug = "-d,crash_after_flush_binlog";

INSERT INTO t2 VALUES(3, repeat('3', 2000000));

SET debug = "+d,crash_after_flush_binlog";
SET debug = "-d,crash_commit_after_sync_to_redo";
INSERT INTO t2 VALUES(4, "4");
INSERT INTO t2 VALUES(5, "5");
--source include/sync_slave_sql_with_master.inc

--echo #
--echo # Case: It should binlog and replicate well w/o this feature
--echo ####################################################################
--echo #
--source include/rpl_connection_master.inc
SET @saved_persist_binlog_to_redo = @@GLOBAL.persist_binlog_to_redo;
SET GLOBAL persist_binlog_to_redo = OFF;
SET debug = "-d,crash_after_flush_binlog";
SET debug = "+d,crash_commit_after_sync_to_redo";

INSERT INTO t2 VALUES(6, "6");
INSERT INTO t2 VALUES(7, "7");

SET debug = "-d,crash_commit_after_sync_to_redo";
SET debug = "+d,crash_after_flush_binlog";
SET GLOBAL persist_binlog_to_redo = ON;
INSERT INTO t2 VALUES(8, "8");
INSERT INTO t2 VALUES(9, "9");
SET debug = "-d,crash_after_flush_binlog";
--source include/sync_slave_sql_with_master.inc
--source include/rpl_connection_master.inc

--echo #
--echo # Case: Lsn checkpoint should wait until binlog is flushed and synced
--echo #########################################################################
--echo #
--source include/rpl_connection_master.inc

SET GLOBAL innodb_log_checkpoint_now = TRUE;

# Block the INSERT just after its binlog is writtent into redo. So it cannot
# be written and synced into binlog. Redo checkpoint will be blocked since the
# binlog is not persisted to binlog yet.
SET debug_sync = "after_write_to_redo SIGNAL redo_written WAIT_FOR continue";
--send INSERT INTO t1 VALUES(101)

--let $rpl_connection_name = server_1
--source include/rpl_connection.inc
SET debug_sync = "now WAIT_FOR redo_written";
--send SET GLOBAL innodb_log_checkpoint_now = TRUE

--let $rpl_connection_name = default
--source include/rpl_connection.inc
# Make sure `SET GLOBAL innodb_log_checkpoint_now` is waiting for checkpoint
# and checkpoint is blocked by binlog sync
--sleep 2

let $wait_condition=
    SELECT count(*) = 1 FROM information_schema.processlist
    WHERE info = "SET GLOBAL innodb_log_checkpoint_now = TRUE";
--source include/wait_condition.inc

SET debug_sync = "now SIGNAL continue";

--let $rpl_connection_name = server_1
--source include/rpl_connection.inc
--reap

--source include/rpl_connection_master.inc
--reap

#
# Clean
#
--source include/rpl_connection_master.inc
DROP TABLE t1, t2;
--remove_file $datadir/binlog_for_recovery
SET GLOBAL persist_binlog_to_redo = @saved_persist_binlog_to_redo;
--source include/rpl_end.inc
