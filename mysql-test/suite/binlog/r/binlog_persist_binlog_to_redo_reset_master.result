SET GLOBAL persist_binlog_to_redo = ON;
CREATE TABLE t1(c1 INT) ENGINE=InnoDB;
FLUSH BINARY LOGS;
INSERT INTO t1 VALUES(1);
RESET MASTER;
SET debug = "d,crash_commit_before_log";
INSERT INTO t1 VALUES(2);
ERROR HY000: Lost connection to MySQL server during query
# restart
# Only the row committed before RESET MASTER is present. The binlog
# records written into redo before RESET MASTER were not replayed.
SELECT * FROM t1;
c1
1
SET GLOBAL persist_binlog_to_redo = default;
DROP TABLE t1;
