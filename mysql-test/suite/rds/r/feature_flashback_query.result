Prepare
create database mytest;
use mytest;
create table t1 (id int key, c1 int);
Init
show variables like "%flashback%";
Variable_name	Value
innodb_rds_flashback_allow_gap	30
innodb_rds_flashback_enabled	ON
innodb_rds_flashback_interval	1
innodb_rds_flashback_print_warning	ON
innodb_rds_flashback_task_enabled	ON
innodb_rds_flashback_task_stop_all	OFF
show variables like "%innodb_undo%";
Variable_name	Value
innodb_undo_directory	./
innodb_undo_log_encrypt	OFF
innodb_undo_log_truncate	ON
innodb_undo_retention	900
innodb_undo_space_reserved_size	0
innodb_undo_space_supremum_size	10240
innodb_undo_tablespaces	2
set @old_innodb_undo_retention = @@global.innodb_undo_retention;
set @old_innodb_rds_flashback_task_enabled = @@global.innodb_rds_flashback_task_enabled;
set @old_innodb_rds_flashback_allow_gap = @@global.innodb_rds_flashback_allow_gap;
set @old_innodb_rds_flashback_print_warning = @@global.innodb_rds_flashback_print_warning;
set global innodb_rds_flashback_task_enabled = 0;
set global innodb_undo_retention = 0;

Case 1 : Normal case
set global innodb_rds_flashback_task_enabled = 1;
set global innodb_undo_retention = 3600;
set global innodb_rds_flashback_allow_gap = 30;
select * from t1;
id	c1
insert into t1 values (1, 1);
insert into t1 values (2, 2);
insert into t1 values (3, 3);
select * from t1;
id	c1
1	1
2	2
3	3
select * from t1 as of timestamp date_sub(now(), interval 5 second);
id	c1
update t1 set c1 = 100;
select * from t1;
id	c1
1	100
2	100
3	100
select * from t1 as of timestamp date_sub(now(), interval 5 second);
id	c1
select * from t1 as of timestamp date_sub(now(), interval 8 second);
id	c1
delete from t1 where id = 1;
select * from t1;
id	c1
2	100
3	100
select * from t1 as of timestamp date_sub(now(), interval 5 second);
id	c1
1	1
2	2
3	3
select * from t1 as of timestamp date_sub(now(), interval 8 second);
id	c1
select * from t1 as of timestamp date_sub(now(), interval 11 second);
id	c1
create table t1_tmp like t1;
insert into t1_tmp select * from t1 as of timestamp date_sub(now(), interval 5 second);
select * from t1_tmp;
id	c1
2	100
3	100
set global innodb_rds_flashback_task_enabled = 0;
set global innodb_undo_retention = 0;
select * from t1;
id	c1
2	100
3	100
select * from t1 as of timestamp date_sub(now(), interval 5 second);
ERROR HY000: The snapshot to find is out of range
select * from t1 as of timestamp date_sub(now(), interval 8 second);
ERROR HY000: The snapshot to find is out of range
select * from t1 as of timestamp date_sub(now(), interval 11 second);
ERROR HY000: The snapshot to find is out of range
drop table t1_tmp;
truncate table t1;
set @case2_start = now();

Case 2 : Error case
set global innodb_rds_flashback_task_enabled = 1;
set global innodb_undo_retention = 3600;
set global innodb_rds_flashback_allow_gap = 1;
select * from t1 as of timestamp now();
ERROR HY000: The snapshot to find is out of range
select * from t1 as of timestamp date_add(now(), interval 5 second);
ERROR HY000: The snapshot to find is out of range
select * from t1 as of timestamp date_sub(now(), interval 5 second);
id	c1
select * from t1 as of timestamp @case2_start;
id	c1
select * from t1 as of timestamp '2000-01-01 00:00:00';
ERROR HY000: The snapshot to find is out of range

Case 3 : multi sessions
set global innodb_rds_flashback_allow_gap = 10;
use mytest;
set @case3_start = now();
set session transaction_isolation = 'REPEATABLE-READ';
begin;
select * from t1;
id	c1
use mytest;
insert into t1 values (1, 1);
use mytest;
insert into t1 values (2, 2);
select sleep(5);
sleep(5)
0
select * from t1;
id	c1
select * from t1 as of timestamp date_sub(now(), interval 3 second);
id	c1
1	1
2	2
select * from t1;
id	c1
commit;
select * from t1;
id	c1
1	1
2	2
select * from t1 as of timestamp date_sub(now(), interval 3 second);
id	c1
1	1
2	2
select * from t1 as of timestamp @case3_start;
id	c1
begin;
insert into t1 values (3, 3);
select sleep(5);
sleep(5)
0
commit;
select * from t1;
id	c1
1	1
2	2
3	3
select * from t1 as of timestamp date_sub(now(), interval 3 second);
id	c1
1	1
2	2
select * from t1 as of timestamp date_sub(now(), interval 8 second);
id	c1
1	1
2	2
select * from t1 as of timestamp @case3_start;
id	c1
set global innodb_rds_flashback_task_enabled = 0;
set global innodb_undo_retention = 0;
truncate table t1;

Case 4 : DDL
set global innodb_rds_flashback_task_enabled = 1;
set global innodb_undo_retention = 3600;
set global innodb_rds_flashback_allow_gap = 30;
select * from t1;
id	c1
insert into t1 values (1,1);
select * from t1;
id	c1
1	1
set @t1 = now();
insert into t1 values (2,2);
select * from t1;
id	c1
1	1
2	2
select * from t1 as of timestamp @t1;
id	c1
1	1
set @t2 = now();
insert into t1 values (3,1);
alter table t1 add index idx_1(c1);
select id from t1 where c1 = 1;
id
1
3
select id from t1 as of timestamp @t2 where c1 = 1;
id
1
alter table t1 add column c2 int;
select * from t1;
id	c1	c2
1	1	NULL
2	2	NULL
3	1	NULL
select * from t1 as of timestamp @t2;
ERROR HY000: The definition of the table required by the flashback query has changed
alter table t1 drop column id;
select * from t1;
c1	c2
1	NULL
2	NULL
1	NULL
select * from t1 as of timestamp @t2;
ERROR HY000: The definition of the table required by the flashback query has changed
drop table t1;
create table t1 (id int key, c1 int);
select * from t1;
id	c1
select * from t1 as of timestamp @t2;
ERROR HY000: The definition of the table required by the flashback query has changed
set global innodb_rds_flashback_task_enabled = 0;
set global innodb_undo_retention = 0;
truncate table t1;

Case 5 : Warning
set @t0 = now();
set global innodb_rds_flashback_task_enabled = 1;
set global innodb_undo_retention = 3600;
set global innodb_rds_flashback_allow_gap = 30;
select * from t1;
id	c1
insert into t1 values (1,1);
select * from t1;
id	c1
1	1
select * from t1 as of timestamp @t0;
id	c1
show warnings;
Level	Code	Message
Warning	#	#
set global innodb_rds_flashback_print_warning = 0;
select * from t1 as of timestamp @t0;
id	c1
show warnings;
Level	Code	Message

Cleanup
use mysql;
drop database mytest;
set global innodb_rds_flashback_task_enabled = @old_innodb_rds_flashback_task_enabled;
set global innodb_undo_retention = @old_innodb_undo_retention;
set global innodb_rds_flashback_allow_gap = @old_innodb_rds_flashback_allow_gap;
set global innodb_rds_flashback_print_warning  = @old_innodb_rds_flashback_print_warning;
